# Copy to .env and fill in your values. Never commit .env to git.

# Database
# Development (SQLite):
DATABASE_URL=sqlite:///fantasai.db
# Production (Railway PostgreSQL — copy from Railway dashboard > Variables):
# DATABASE_URL=postgresql://user:password@host.railway.internal:5432/railway

# Anthropic (required for LLM blurbs)
ANTHROPIC_API_KEY=sk-ant-...

# Optional integrations (not required for core features)
THE_ODDS_API_KEY=your_the_odds_api_key_here
OPENWEATHER_API_KEY=

# Environment
ENV=development
LOG_LEVEL=INFO

# Firebase (server-side token verification)
FIREBASE_PROJECT_ID=fantasaisports-fantasy-gm
FIREBASE_WEB_API_KEY=

# Yahoo Fantasy OAuth
YAHOO_CLIENT_ID=
YAHOO_CLIENT_SECRET=
YAHOO_REDIRECT_URI=https://your-domain.com/api/v1/auth/yahoo/callback

# Token encryption key (generate: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
TOKEN_ENCRYPTION_KEY=

# Email (Resend — https://resend.com)
RESEND_API_KEY=

# App base URL
APP_URL=https://your-domain.com
