# Copy to .env and fill in your values. Never commit .env to git.

# Database
# Development (SQLite):
DATABASE_URL=sqlite:///fantasai.db
# Production (Railway PostgreSQL — copy from Railway dashboard > Variables):
# DATABASE_URL=postgresql://user:password@host.railway.internal:5432/railway

# Anthropic (required for LLM blurbs)
ANTHROPIC_API_KEY=sk-ant-...

# Optional integrations (not required for core features)
ODDS_API_KEY=
OPENWEATHER_API_KEY=

# Environment
ENV=development
LOG_LEVEL=INFO
